//===========================
//==========TASK 1.6=========
//  Клас Vector3F
//===========================
class Vector3F {
private:
    float x, y, z;
    int State;
    static int count;

public:
    // Конструктор без параметрів
    Vector3F() : x(0), y(0), z(0), State(0) {
        count++;
    }

    // Конструктор з одним параметром float
    Vector3F(float val) : x(val), y(val), z(val), State(0) {
        count++;
    }

    // Конструктор з вказівником
    Vector3F(float* arr) : State(0) {
        if (arr == nullptr) {
            x = y = z = 0;
            State = -1;
            cout << "Vector3F: error - nullptr" << endl;
        }
        else {
            x = arr[0]; y = arr[1]; z = arr[2];
        }
        count++;
    }

    // Конструктор копіювання
    Vector3F(const Vector3F& other) : x(other.x), y(other.y), z(other.z), State(other.State) {
        count++;
    }

    // Деструктор
    ~Vector3F() {
        cout << "Vector3F destroyed: (" << x << "," << y << "," << z << ") State=" << State << endl;
        count--;
    }

    static int getCount() { return count; }
    int getState() const { return State; }
    float getX() const { return x; }
    float getY() const { return y; }
    float getZ() const { return z; }

    // Оператор присвоєння
    Vector3F& operator=(const Vector3F& b) {
        if (this != &b) { x = b.x; y = b.y; z = b.z; State = b.State; }
        return *this;
    }

    // Унарний префіксний ++
    Vector3F& operator++() {
        x++; y++; z++;
        return *this;
    }

    // Унарний постфіксний ++
    Vector3F operator++(int) {
        Vector3F temp(*this);
        x++; y++; z++;
        return temp;
    }

    // Унарний префіксний --
    Vector3F& operator--() {
        x--; y--; z--;
        return *this;
    }

    // Унарний постфіксний --
    Vector3F operator--(int) {
        Vector3F temp(*this);
        x--; y--; z--;
        return temp;
    }

    // Унарний ! - true якщо x,y,z не дорівнюють нулю
    bool operator!() const {
        return (x != 0 && y != 0 && z != 0);
    }

    // Унарний ~ - перпендикулярний вектор
    Vector3F operator~() const {
        Vector3F temp;
        temp.x = -y;
        temp.y = x;
        temp.z = 0;
        return temp;
    }

    // Унарний мінус
    Vector3F operator-() const {
        Vector3F temp;
        temp.x = -x; temp.y = -y; temp.z = -z;
        return temp;
    }

    // +=
    Vector3F& operator+=(const Vector3F& b) {
        x += b.x; y += b.y; z += b.z;
        return *this;
    }

    // -=
    Vector3F& operator-=(const Vector3F& b) {
        x -= b.x; y -= b.y; z -= b.z;
        return *this;
    }

    // *= число
    Vector3F& operator*=(float b) {
        x *= b; y *= b; z *= b;
        return *this;
    }

    // /= число
    Vector3F& operator/=(float b) {
        if (b == 0) { State = -2; cout << "Error: division by zero" << endl; return *this; }
        x /= b; y /= b; z /= b;
        return *this;
    }

    // &= векторний добуток
    Vector3F& operator&=(const Vector3F& b) {
        float nx = y * b.z - z * b.y;
        float ny = z * b.x - x * b.z;
        float nz = x * b.y - y * b.x;
        x = nx; y = ny; z = nz;
        return *this;
    }

    // %= остача від ділення цілої частини на int
    Vector3F& operator%=(int b) {
        if (b == 0) { State = -2; cout << "Error: division by zero" << endl; return *this; }
        x = (float)((int)x % b);
        y = (float)((int)y % b);
        z = (float)((int)z % b);
        return *this;
    }

    // + додавання векторів
    Vector3F operator+(const Vector3F& b) const {
        Vector3F temp;
        temp.x = x + b.x; temp.y = y + b.y; temp.z = z + b.z;
        return temp;
    }

    // - віднімання векторів
    Vector3F operator-(const Vector3F& b) const {
        Vector3F temp;
        temp.x = x - b.x; temp.y = y - b.y; temp.z = z - b.z;
        return temp;
    }

    // * множення на число
    Vector3F operator*(float b) const {
        Vector3F temp;
        temp.x = x * b; temp.y = y * b; temp.z = z * b;
        return temp;
    }

    // / ділення на число
    Vector3F operator/(float b) const {
        Vector3F temp;
        if (b == 0) { temp.State = -2; cout << "Error: division by zero" << endl; return temp; }
        temp.x = x / b; temp.y = y / b; temp.z = z / b;
        return temp;
    }

    // % остача
    Vector3F operator%(int b) const {
        Vector3F temp;
        if (b == 0) { temp.State = -2; cout << "Error: division by zero" << endl; return temp; }
        temp.x = (float)((int)x % b);
        temp.y = (float)((int)y % b);
        temp.z = (float)((int)z % b);
        return temp;
    }

    // == рівність
    bool operator==(const Vector3F& b) const {
        return x == b.x && y == b.y && z == b.z;
    }

    // != нерівність
    bool operator!=(const Vector3F& b) const {
        return !(*this == b);
    }

    // > більше (порівняння довжин)
    bool operator>(const Vector3F& b) const {
        return (x * x + y * y + z * z) > (b.x * b.x + b.y * b.y + b.z * b.z);
    }

    // >= більше або рівне
    bool operator>=(const Vector3F& b) const {
        return (x * x + y * y + z * z) >= (b.x * b.x + b.y * b.y + b.z * b.z);
    }

    // < менше
    bool operator<(const Vector3F& b) const {
        return (x * x + y * y + z * z) < (b.x * b.x + b.y * b.y + b.z * b.z);
    }

    // <= менше або рівне
    bool operator<=(const Vector3F& b) const {
        return (x * x + y * y + z * z) <= (b.x * b.x + b.y * b.y + b.z * b.z);
    }

    // [] індексація: 0->x, 1->y, 2->z
    float& operator[](int i) {
        if (i == 0) return x;
        if (i == 1) return y;
        if (i == 2) { return z; }
        cout << "Error: invalid index, returning z" << endl;
        State = -3;
        return z;
    }

    // () виклик функції - виводить довжину вектора
    float operator()() const {
        return sqrt(x * x + y * y + z * z);
    }

    // new і delete
    void* operator new(size_t size) {
        void* ptr = malloc(size);
        if (!ptr) { cout << "Error: memory allocation failed" << endl; }
        return ptr;
    }

    void operator delete(void* ptr) {
        free(ptr);
    }

    // >> введення (дружня)
    friend istream& operator>>(istream& in, Vector3F& v) {
        in >> v.x >> v.y >> v.z;
        return in;
    }

    // << виведення (дружня)
    friend ostream& operator<<(ostream& out, const Vector3F& v) {
        out << "(" << v.x << ", " << v.y << ", " << v.z << ")";
        return out;
    }
};

