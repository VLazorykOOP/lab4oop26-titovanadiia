//  Email та ПІБ
//===========================
class EmailPIB {
private:
    char** emails;
    char** pibs;
    int size;
    int maxSize;
    int CodeError;

public:
    EmailPIB() : size(0), maxSize(10), CodeError(0) {
        emails = new char* [maxSize];
        pibs = new char* [maxSize];
    }

    EmailPIB(int max) : size(0), maxSize(max), CodeError(0) {
        emails = new char* [maxSize];
        pibs = new char* [maxSize];
    }

    ~EmailPIB() {
        for (int i = 0; i < size; i++) {
            delete[] emails[i];
            delete[] pibs[i];
        }
        delete[] emails;
        delete[] pibs;
    }

    // Додати запис
    void add(const char* email, const char* pib) {
        if (size >= maxSize) {
            cout << "Error: storage full" << endl;
            CodeError = -1;
            return;
        }
        emails[size] = new char[strlen(email) + 1];
        pibs[size] = new char[strlen(pib) + 1];
        strcpy(emails[size], email);
        strcpy(pibs[size], pib);
        size++;
    }

    // Вивести всю таблицю
    void print() const {
        cout << "\n--- Email-PIB Table ---" << endl;
        for (int i = 0; i < size; i++) {
            cout << emails[i] << " -> " << pibs[i] << endl;
        }
    }

    // [] пошук ПІБ за email
    char* operator[](const char* email) {
        for (int i = 0; i < size; i++) {
            if (strcmp(emails[i], email) == 0) return pibs[i];
        }
        cout << "Error: email not found" << endl;
        CodeError = -2;
        return nullptr;
    }

    // () пошук email за ПІБ
    char* operator()(const char* pib) {
        for (int i = 0; i < size; i++) {
            if (strcmp(pibs[i], pib) == 0) return emails[i];
        }
        cout << "Error: PIB not found" << endl;
        CodeError = -3;
        return nullptr;
    }

    // >> введення (дружня)
    friend istream& operator>>(istream& in, EmailPIB& db) {
        char email[100], pib[200];
        cout << "Enter email: "; in >> email;
        cout << "Enter PIB: ";
        in.ignore();
        in.getline(pib, 200);
        db.add(email, pib);
        return in;
    }

    // << виведення (дружня)
    friend ostream& operator<<(ostream& out, const EmailPIB& db) {
        for (int i = 0; i < db.size; i++) {
            out << db.emails[i] << " -> " << db.pibs[i] << endl;
        }
        return out;
    }
};

