//===========================
//  Клас MatrixShort
//===========================
class MatrixShort {
protected:
    VectorShort* ShortArray;
    int n, size;
    int codeError;
    static int num_matrix;

public:
    MatrixShort() : ShortArray(nullptr), n(0), size(0), codeError(0) {
        num_matrix++;
    }

    // Одинична матриця n x n
    MatrixShort(int sz) : n(sz), size(sz), codeError(0) {
        ShortArray = new VectorShort[n];
        for (int i = 0; i < n; i++) {
            ShortArray[i] = VectorShort(size, 0);
            ShortArray[i][i] = 1;
        }
        num_matrix++;
    }

    // Матриця n x sz
    MatrixShort(int rows, int cols) : n(rows), size(cols), codeError(0) {
        ShortArray = new VectorShort[n];
        for (int i = 0; i < n; i++) ShortArray[i] = VectorShort(size, 0);
        num_matrix++;
    }

    // Матриця n x sz з початковим значенням
    MatrixShort(int rows, int cols, short val) : n(rows), size(cols), codeError(0) {
        ShortArray = new VectorShort[n];
        for (int i = 0; i < n; i++) ShortArray[i] = VectorShort(size, val);
        num_matrix++;
    }

    // Конструктор копіювання
    MatrixShort(const MatrixShort& other) : n(other.n), size(other.size), codeError(other.codeError) {
        ShortArray = new VectorShort[n];
        for (int i = 0; i < n; i++) ShortArray[i] = other.ShortArray[i];
        num_matrix++;
    }

    ~MatrixShort() {
        delete[] ShortArray;
        num_matrix--;
    }

    int getN() const { return n; }
    int getSize() const { return size; }
    int getCodeError() const { return codeError; }
    static int getNumMatrix() { return num_matrix; }

    MatrixShort& operator=(const MatrixShort& b) {
        if (this != &b) {
            delete[] ShortArray;
            n = b.n; size = b.size; codeError = b.codeError;
            ShortArray = new VectorShort[n];
            for (int i = 0; i < n; i++) ShortArray[i] = b.ShortArray[i];
        }
        return *this;
    }

    MatrixShort& operator++() {
        for (int i = 0; i < n; i++) ++ShortArray[i];
        return *this;
    }

    MatrixShort operator++(int) {
        MatrixShort temp(*this);
        for (int i = 0; i < n; i++) ShortArray[i]++;
        return temp;
    }

    MatrixShort& operator--() {
        for (int i = 0; i < n; i++) --ShortArray[i];
        return *this;
    }

    MatrixShort operator--(int) {
        MatrixShort temp(*this);
        for (int i = 0; i < n; i++) ShortArray[i]--;
        return temp;
    }

    bool operator!() const { return n != 0 && size != 0; }

    MatrixShort operator~() const {
        MatrixShort temp(n, size);
        for (int i = 0; i < n; i++) temp.ShortArray[i] = ~ShortArray[i];
        return temp;
    }

    MatrixShort operator-() const {
        MatrixShort temp(n, size);
        for (int i = 0; i < n; i++) temp.ShortArray[i] = -ShortArray[i];
        return temp;
    }

    MatrixShort operator+(const MatrixShort& b) const {
        MatrixShort temp(n, size);
        for (int i = 0; i < n; i++) temp.ShortArray[i] = ShortArray[i] + b.ShortArray[i];
        return temp;
    }

    MatrixShort operator+(short b) const {
        MatrixShort temp(n, size);
        VectorShort vb(size, b);
        for (int i = 0; i < n; i++) temp.ShortArray[i] = ShortArray[i] + vb;
        return temp;
    }

    MatrixShort operator-(const MatrixShort& b) const {
        MatrixShort temp(n, size);
        for (int i = 0; i < n; i++) temp.ShortArray[i] = ShortArray[i] - b.ShortArray[i];
        return temp;
    }

    MatrixShort operator-(short b) const {
        MatrixShort temp(n, size);
        VectorShort vb(size, b);
        for (int i = 0; i < n; i++) temp.ShortArray[i] = ShortArray[i] - vb;
        return temp;
    }

    MatrixShort operator*(const MatrixShort& b) const {
        MatrixShort temp(n, b.size);
        for (int i = 0; i < n; i++)
            for (int j = 0; j < b.size; j++) {
                short s = 0;
                for (int k = 0; k < size; k++) s += ShortArray[i][k] * b.ShortArray[k][j];
                temp.ShortArray[i][j] = s;
            }
        return temp;
    }

    MatrixShort operator*(short b) const {
        MatrixShort temp(n, size);
        for (int i = 0; i < n; i++) temp.ShortArray[i] = ShortArray[i] * b;
        return temp;
    }

    MatrixShort operator/(short b) const {
        MatrixShort temp(n, size);
        if (b == 0) { temp.codeError = -1; cout << "Error: division by zero" << endl; return temp; }
