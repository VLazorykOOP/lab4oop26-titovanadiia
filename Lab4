class VectorShort {
private:
    short* data;
    int size;
    int codeError;
    static int count;

public:
    VectorShort() : size(1), codeError(0) {
        data = new short[1];
        data[0] = 0;
        count++;
    }

    VectorShort(int sz) : size(sz), codeError(0) {
        data = new short[sz];
        for (int i = 0; i < sz; i++) data[i] = 0;
        count++;
    }

    VectorShort(int sz, short val) : size(sz), codeError(0) {
        data = new short[sz];
        for (int i = 0; i < sz; i++) data[i] = val;
        count++;
    }

    VectorShort(const VectorShort& other) : size(other.size), codeError(other.codeError) {
        data = new short[size];
        for (int i = 0; i < size; i++) data[i] = other.data[i];
        count++;
    }

    ~VectorShort() {
        delete[] data;
        count--;
    }

    int getSize() const { return size; }
    int getCodeError() const { return codeError; }
    static int getCount() { return count; }

    VectorShort& operator=(const VectorShort& b) {
        if (this != &b) {
            delete[] data;
            size = b.size;
            data = new short[size];
            for (int i = 0; i < size; i++) data[i] = b.data[i];
            codeError = b.codeError;
        }
        return *this;
    }

    // Префіксний ++
    VectorShort& operator++() {
        for (int i = 0; i < size; i++) data[i]++;
        return *this;
    }

    // Постфіксний ++
    VectorShort operator++(int) {
        VectorShort temp(*this);
        for (int i = 0; i < size; i++) data[i]++;
        return temp;
    }

    // Префіксний --
    VectorShort& operator--() {
        for (int i = 0; i < size; i++) data[i]--;
        return *this;
    }

    // Постфіксний --
    VectorShort operator--(int) {
        VectorShort temp(*this);
        for (int i = 0; i < size; i++) data[i]--;
        return temp;
    }

    bool operator!() const { return size != 0; }

    VectorShort operator~() const {
        VectorShort temp(size);
        for (int i = 0; i < size; i++) temp.data[i] = ~data[i];
        return temp;
    }

    VectorShort operator-() const {
        VectorShort temp(size);
        for (int i = 0; i < size; i++) temp.data[i] = -data[i];
        return temp;
    }

    VectorShort& operator+=(const VectorShort& b) {
        int n = min(size, b.size);
        for (int i = 0; i < n; i++) data[i] += b.data[i];
        return *this;
    }

    VectorShort& operator-=(const VectorShort& b) {
        int n = min(size, b.size);
        for (int i = 0; i < n; i++) data[i] -= b.data[i];
        return *this;
    }

    VectorShort& operator*=(short b) {
        for (int i = 0; i < size; i++) data[i] *= b;
        return *this;
    }

    VectorShort& operator/=(short b) {
        if (b == 0) { codeError = -1; cout << "Error: division by zero" << endl; return *this; }
        for (int i = 0; i < size; i++) data[i] /= b;
        return *this;
    }

    VectorShort& operator%=(short b) {
        if (b == 0) { codeError = -1; cout << "Error: division by zero" << endl; return *this; }
        for (int i = 0; i < size; i++) data[i] %= b;
        return *this;
    }

    VectorShort& operator|=(const VectorShort& b) {
        int n = min(size, b.size);
        for (int i = 0; i < n; i++) data[i] |= b.data[i];
        return *this;
    }

    VectorShort& operator^=(const VectorShort& b) {
        int n = min(size, b.size);
        for (int i = 0; i < n; i++) data[i] ^= b.data[i];
        return *this;
    }

    VectorShort& operator&=(const VectorShort& b) {
        int n = min(size, b.size);
        for (int i = 0; i < n; i++) data[i] &= b.data[i];
        return *this;
    }

    VectorShort operator+(const VectorShort& b) const {
        VectorShort temp(min(size, b.size));
        for (int i = 0; i < temp.size; i++) temp.data[i] = data[i] + b.data[i];
        return temp;
    }

    VectorShort operator-(const VectorShort& b) const {
        VectorShort temp(min(size, b.size));
        for (int i = 0; i < temp.size; i++) temp.data[i] = data[i] - b.data[i];
        return temp;
    }

    VectorShort operator*(short b) const {
        VectorShort temp(size);
        for (int i = 0; i < size; i++) temp.data[i] = data[i] * b;
        return temp;
    }

    VectorShort operator/(short b) const {
        VectorShort temp(size);
        if (b == 0) { temp.codeError = -1; cout << "Error: division by zero" << endl; return temp; }
        for (int i = 0; i < size; i++) temp.data[i] = data[i] / b;
        return temp;
    }

    VectorShort operator%(short b) const {
        VectorShort temp(size);
        if (b == 0) { temp.codeError = -1; cout << "Error: division by zero" << endl; return temp; }
        for (int i = 0; i < size; i++) temp.data[i] = data[i] % b;
        return temp;
    }

    VectorShort operator|(const VectorShort& b) const {
        VectorShort temp(min(size, b.size));
        for (int i = 0; i < temp.size; i++) temp.data[i] = data[i] | b.data[i];
        return temp;
    }

    VectorShort operator^(const VectorShort& b) const {
        VectorShort temp(min(size, b.size));
        for (int i = 0; i < temp.size; i++) temp.data[i] = data[i] ^ b.data[i];
        return temp;
    }

    VectorShort operator&(const VectorShort& b) const {
        VectorShort temp(min(size, b.size));
        for (int i = 0; i < temp.size; i++) temp.data[i] = data[i] & b.data[i];
        return temp;
    }

    bool operator==(const VectorShort& b) const {
        if (size != b.size) return false;
        for (int i = 0; i < size; i++) if (data[i] != b.data[i]) return false;
        return true;
    }

    bool operator!=(const VectorShort& b) const { return !(*this == b); }

    bool operator>(const VectorShort& b) const {
        int n = min(size, b.size);
        for (int i = 0; i < n; i++) if (data[i] <= b.data[i]) return false;
        return true;
    }

    bool operator>=(const VectorShort& b) const {
        int n = min(size, b.size);
        for (int i = 0; i < n; i++) if (data[i] < b.data[i]) return false;
        return true;
    }

    bool operator<(const VectorShort& b) const {
        int n = min(size, b.size);
        for (int i = 0; i < n; i++) if (data[i] >= b.data[i]) return false;
        return true;
    }

    bool operator<=(const VectorShort& b) const {
        int n = min(size, b.size);
        for (int i = 0; i < n; i++) if (data[i] > b.data[i]) return false;
        return true;
    }

    short& operator[](int i) {
        if (i < 0 || i >= size) {
            cout << "Error: index out of range, returning last element" << endl;
            codeError = -2;
            return data[size - 1];
        }
        return data[i];
    }

    void operator()() const {
        cout << "VectorShort[" << size << "]: ";
        for (int i = 0; i < size; i++) cout << data[i] << " ";
        cout << endl;
    }

    void* operator new(size_t sz) {
        void* ptr = malloc(sz);
        if (!ptr) cout << "Error: memory allocation failed" << endl;
        return ptr;
    }

    void operator delete(void* ptr) { free(ptr); }

    friend istream& operator>>(istream& in, VectorShort& v) {
        for (int i = 0; i < v.size; i++) in >> v.data[i];
        return in;
    }

    friend ostream& operator<<(ostream& out, const VectorShort& v) {
        out << "[";
        for (int i = 0; i < v.size; i++) {
            out << v.data[i];
            if (i < v.size - 1) out << ", ";
        }
        out << "]";
        return out;
    }
};

